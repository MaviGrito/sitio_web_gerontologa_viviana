---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/layout/Header.astro';
import { SITE_CONFIG } from '../utils/constants';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('blog');
const latestPosts = allPosts
  .filter(post => !post.data.draft)
  .sort((a, b) => new Date(b.data.publishDate).getTime() - new Date(a.data.publishDate).getTime())
  .slice(0, 3);

const allServices = await getCollection('services');
const activeServices = allServices
  .filter(service => service.data.active)
  .sort((a, b) => (a.data.order || 0) - (b.data.order || 0));

const categoryLabels = {
  'gerontologia': 'Gerontología',
  'familias-cuidadores': 'Familias y Cuidadores',
  'demencias-alzheimer': 'Demencias y Alzheimer',
  'salud-bienestar': 'Salud y Bienestar',
  'envejecimiento-sociedad': 'Envejecimiento y Sociedad',
  'recursos-herramientas': 'Recursos y Herramientas',
  'experiencias-reflexiones': 'Experiencias y Reflexiones',
  'nutricion': 'Familias y Cuidadores',
  'ejercicio': 'Demencias y Alzheimer',
  'salud-mental': 'Salud y Bienestar'
};

const serviceIcons = {
  'check-circle': 'M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z',
  'clipboard-list': 'M9 5H7a2 2 0 00-2 2v10a2 2 0 002 2h8a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2',
  'users': 'M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z',
  'lightbulb': 'M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z',
  'office-building': 'M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4',
  'megaphone': 'M11 5.882V19.24a1.76 1.76 0 01-3.417.592l-2.147-6.15M18 13a3 3 0 100-6M5.436 13.683A4.001 4.001 0 017 6h1.832c4.1 0 7.625-1.234 9.168-3v14c-1.543-1.766-5.067-3-9.168-3H7a3.988 3.988 0 01-1.564-.317z'
};

function formatDate(date: Date): string {
  return new Intl.DateTimeFormat('es-ES', { year: 'numeric', month: 'long', day: 'numeric' }).format(date);
}
---

<BaseLayout title={SITE_CONFIG.title} description={SITE_CONFIG.description}>
  <Header currentPath="/" />
  <main class="flex-1">

    <!-- ═══════════════════════════════════════════════
         HERO — Pregunta impactante + foto + CTA
    ═══════════════════════════════════════════════ -->
    <section class="hero-section relative overflow-hidden" style="background: linear-gradient(135deg, #7FFFD4 0%, #5CE8C0 30%, #B8F5C8 70%, #E8FDF0 100%); min-height: 92vh; display: flex; align-items: center;">
      <!-- Círculos decorativos -->
      <div class="absolute top-0 left-0 w-96 h-96 rounded-full opacity-20" style="background: radial-gradient(circle, #ffffff 0%, transparent 70%); transform: translate(-30%, -30%);"></div>
      <div class="absolute bottom-0 right-0 w-80 h-80 rounded-full opacity-15" style="background: radial-gradient(circle, #136038 0%, transparent 70%); transform: translate(30%, 30%);"></div>

      <div class="container mx-auto px-4 sm:px-6 lg:px-8 py-16 lg:py-24 relative z-10">
        <div class="max-w-6xl mx-auto">
          <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">

            <!-- Contenido -->
            <div class="hero-content order-2 lg:order-1">
              <!-- Pregunta impactante -->
              <div class="hero-question mb-6">
                <p class="text-sm font-heading font-bold uppercase tracking-widest mb-3" style="color: #136038; letter-spacing: 0.15em;">Gerontología Profesional · Medellín</p>
                <h1 class="font-heading font-extrabold leading-tight mb-4" style="font-size: clamp(2rem, 5vw, 3.2rem); color: #0d4a2a;">
                  ¿Buscas apoyo profesional para el bienestar y cuidado de una persona mayor?
                </h1>
                <div class="w-16 h-1 rounded-full mb-6" style="background: #136038;"></div>
              </div>

              <h2 class="text-lg lg:text-xl font-body mb-4" style="color: #1a5c35; font-weight: 600;">
                {SITE_CONFIG.author.name}
              </h2>
              <p class="text-base font-body mb-6 leading-relaxed text-justify" style="color: #1e6b3e;">
                {SITE_CONFIG.description}
              </p>

              <!-- CTA Buttons -->
              <div class="flex flex-col sm:flex-row gap-4">
                <a
                  href={`https://wa.me/${SITE_CONFIG.contact.whatsapp.replace(/[^0-9]/g, '')}?text=Hola, me gustaría agendar una consulta gerontológica`}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="hero-cta-primary inline-flex items-center justify-center gap-2 px-8 py-4 rounded-xl font-heading font-bold text-white shadow-xl transition-all duration-300"
                  style="background: linear-gradient(135deg, #136038, #03A63C); font-size: 1.05rem;"
                >
                  <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893A11.821 11.821 0 0020.885 3.488"/></svg>
                  Agendar Consulta
                </a>
                <a href="/servicios" class="inline-flex items-center justify-center gap-2 px-8 py-4 rounded-xl font-heading font-bold border-2 transition-all duration-300" style="border-color: #136038; color: #136038; background: rgba(255,255,255,0.6);">
                  Ver Servicios
                </a>
              </div>
            </div>

            <!-- Foto -->
            <div class="hero-image order-1 lg:order-2 flex justify-center">
              <div class="relative">
                <div class="w-72 h-72 lg:w-96 lg:h-96 rounded-full overflow-hidden shadow-2xl border-4" style="border-color: rgba(255,255,255,0.8);">
                  <img
                    src={SITE_CONFIG.author.photo}
                    alt={`${SITE_CONFIG.author.name}, Gerontóloga`}
                    class="w-full h-full object-cover"
                    loading="eager"
                  />
                </div>
                <!-- Badge flotante -->
                <div class="absolute -bottom-4 -right-4 bg-white rounded-2xl shadow-xl px-4 py-3 flex items-center gap-2">
                  <div class="w-3 h-3 rounded-full bg-green-400 animate-pulse"></div>
                  <span class="text-sm font-heading font-bold" style="color: #136038;">Disponible para consulta</span>
                </div>
                <!-- Decorativo -->
                <div class="absolute -top-6 -left-6 w-20 h-20 rounded-full opacity-40" style="background: linear-gradient(135deg, #5CE8C0, #7FFFD4);"></div>
              </div>
            </div>

          </div>
        </div>
      </div>

      <!-- Wave inferior -->
      <div class="absolute bottom-0 left-0 w-full overflow-hidden leading-none">
        <svg viewBox="0 0 1440 60" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="none" style="display:block; width:100%; height:60px;">
          <path d="M0,30 C360,60 1080,0 1440,30 L1440,60 L0,60 Z" fill="#ffffff"/>
        </svg>
      </div>
    </section>


    <!-- ═══════════════════════════════════════════════
         STATS — Números con count-up animation
    ═══════════════════════════════════════════════ -->
    <section class="stats-section py-20" style="background: #ffffff;">
      <div class="container mx-auto px-4 sm:px-6 lg:px-8">
        <div class="max-w-5xl mx-auto">
          <div class="grid grid-cols-1 md:grid-cols-3 gap-8 text-center">

            <div class="stat-card animate-on-scroll p-8 rounded-2xl" style="background: linear-gradient(135deg, #f0fdf9, #e0faf2); border: 1px solid #b8f5c8;">
              <div class="stat-number font-heading font-extrabold mb-2" data-target="100" style="font-size: 4rem; color: #136038; line-height: 1;">
                0
              </div>
              <div class="text-2xl font-heading font-bold mb-1" style="color: #136038;">+</div>
              <p class="font-body font-semibold text-gray-600 text-lg">Personas mayores y familias acompañadas</p>
            </div>

            <div class="stat-card animate-on-scroll p-8 rounded-2xl" style="background: linear-gradient(135deg, #f0fdf9, #e0faf2); border: 1px solid #b8f5c8; animation-delay: 150ms;">
              <div class="stat-number font-heading font-extrabold mb-2" data-target="5" style="font-size: 4rem; color: #136038; line-height: 1;">
                0
              </div>
              <div class="text-2xl font-heading font-bold mb-1" style="color: #136038;">+</div>
              <p class="font-body font-semibold text-gray-600 text-lg">Años de experiencia en gerontología</p>
            </div>

            <div class="stat-card animate-on-scroll p-8 rounded-2xl" style="background: linear-gradient(135deg, #f0fdf9, #e0faf2); border: 1px solid #b8f5c8; animation-delay: 300ms;">
              <div class="stat-number font-heading font-extrabold mb-2" data-target="6" style="font-size: 4rem; color: #136038; line-height: 1;">
                0
              </div>
              <div class="text-2xl font-heading font-bold mb-1" style="color: #136038;"></div>
              <p class="font-body font-semibold text-gray-600 text-lg">Servicios especializados disponibles</p>
            </div>

          </div>
        </div>
      </div>
    </section>


    <!-- ═══════════════════════════════════════════════
         SERVICIOS
    ═══════════════════════════════════════════════ -->
    <section class="services-preview py-20 relative overflow-hidden" style="background: linear-gradient(160deg, #5CE8C0 0%, #7FFFD4 40%, #B8F5C8 100%);">
      <!-- Wave superior -->
      <div class="absolute top-0 left-0 w-full overflow-hidden leading-none" style="transform: rotate(180deg);">
        <svg viewBox="0 0 1440 60" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="none" style="display:block; width:100%; height:60px;">
          <path d="M0,30 C360,60 1080,0 1440,30 L1440,60 L0,60 Z" fill="#ffffff"/>
        </svg>
      </div>

      <div class="container mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
        <div class="max-w-4xl mx-auto text-center mb-14 animate-on-scroll">
          <p class="text-sm font-heading font-bold uppercase tracking-widest mb-3" style="color: #0d4a2a;">Lo que ofrezco</p>
          <h2 class="text-3xl lg:text-4xl font-heading font-extrabold mb-4" style="color: #0d4a2a;">
            Servicios Especializados
          </h2>
          <p class="text-lg font-body" style="color: #1a5c35;">
            Atención integral para el bienestar y calidad de vida de las personas mayores
          </p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
          {activeServices.map((service, i) => (
            <div class="service-card animate-on-scroll bg-white rounded-2xl p-6 shadow-lg hover:shadow-2xl transition-all duration-300 hover:-translate-y-2 text-center" style={`animation-delay: ${i * 100}ms;`}>
              <div class="w-14 h-14 rounded-2xl flex items-center justify-center mx-auto mb-4" style="background: linear-gradient(135deg, #5CE8C0, #7FFFD4);">
                <svg class="w-7 h-7" fill="none" stroke="#136038" stroke-width="2" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" d={serviceIcons[service.data.icon] || serviceIcons['check-circle']}/>
                </svg>
              </div>
              <h3 class="text-lg font-heading font-bold mb-2" style="color: #136038;">{service.data.title}</h3>
              <p class="font-body text-gray-600 text-sm leading-relaxed">{service.data.description}</p>
            </div>
          ))}
        </div>

        <div class="text-center mt-12 animate-on-scroll">
          <a href="/servicios" class="inline-flex items-center gap-2 px-8 py-4 rounded-xl font-heading font-bold text-white shadow-xl transition-all duration-300 hover:scale-105" style="background: linear-gradient(135deg, #136038, #03A63C);">
            Ver Todos los Servicios
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
          </a>
        </div>
      </div>

      <!-- Wave inferior -->
      <div class="absolute bottom-0 left-0 w-full overflow-hidden leading-none">
        <svg viewBox="0 0 1440 60" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="none" style="display:block; width:100%; height:60px;">
          <path d="M0,30 C360,0 1080,60 1440,30 L1440,60 L0,60 Z" fill="#ffffff"/>
        </svg>
      </div>
    </section>


    <!-- ═══════════════════════════════════════════════
         SOBRE MÍ
    ═══════════════════════════════════════════════ -->
    <section class="about-section py-20 relative" style="background: linear-gradient(135deg, #0d4a2a 0%, #136038 50%, #03A63C 100%);">
      <div class="absolute inset-0 opacity-5" style="background-image: url('data:image/svg+xml,<svg width=\'40\' height=\'40\' viewBox=\'0 0 40 40\' xmlns=\'http://www.w3.org/2000/svg\'><circle cx=\'20\' cy=\'20\' r=\'1.5\' fill=\'%23ffffff\'/></svg>');"></div>
      <div class="container mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
        <div class="max-w-4xl mx-auto animate-on-scroll">
          <div class="text-center mb-10">
            <p class="text-sm font-heading font-bold uppercase tracking-widest mb-3" style="color: #7FFFD4;">Mi historia</p>
            <h2 class="text-3xl lg:text-4xl font-heading font-extrabold text-white mb-4">Sobre Mí</h2>
            <div class="w-16 h-1 rounded-full mx-auto" style="background: #7FFFD4;"></div>
          </div>
          <p class="text-lg font-body leading-relaxed text-justify" style="color: rgba(255,255,255,0.9);">
            {SITE_CONFIG.author.bio}
          </p>
        </div>
      </div>
    </section>

    <!-- ═══════════════════════════════════════════════
         MAPA
    ═══════════════════════════════════════════════ -->
    <section class="map-section py-20" style="background: #ffffff;">
      <div class="container mx-auto px-4 sm:px-6 lg:px-8">
        <div class="max-w-4xl mx-auto text-center mb-10 animate-on-scroll">
          <p class="text-sm font-heading font-bold uppercase tracking-widest mb-3" style="color: #136038;">Cobertura</p>
          <h2 class="text-3xl lg:text-4xl font-heading font-extrabold mb-4" style="color: #0d4a2a;">Encuéntranos</h2>
          <p class="text-lg font-body text-gray-600">Servicios disponibles en el Área Metropolitana del Valle de Aburrá</p>
        </div>
        <div class="max-w-4xl mx-auto rounded-2xl overflow-hidden shadow-xl animate-on-scroll">
          <a
            href="https://www.google.com/maps/place/Geront%C3%B3loga+Viviana+Tonguino+Guerrero/@6.2472116,-75.6814308,10z/data=!4m6!3m5!1s0x41c625af58b7085b:0x3db1a3ddc60a18e0!8m2!3d6.2435291!4d-75.4680945!16s%2Fg%2F11yxzl109z"
            target="_blank" rel="noopener noreferrer"
            class="block relative group"
            aria-label="Ver perfil de Viviana Tonguino Guerrero en Google Maps"
          >
            <iframe
              src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d126289.84!2d-75.6814308!3d6.2472116!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x41c625af58b7085b%3A0x3db1a3ddc60a18e0!2sGeront%C3%B3loga%20Viviana%20Tonguino%20Guerrero!5e0!3m2!1ses!2sco!4v1700000000000!5m2!1ses!2sco"
              width="100%" height="420" style="border:0; display:block; pointer-events:none;"
              allowfullscreen="" loading="lazy" referrerpolicy="no-referrer-when-downgrade"
              title="Gerontóloga Viviana Tonguino Guerrero"
            ></iframe>
            <div class="absolute inset-0 bg-primary/0 group-hover:bg-primary/10 transition-colors duration-300 flex items-center justify-center">
              <span class="opacity-0 group-hover:opacity-100 transition-opacity duration-300 bg-white font-heading font-bold px-5 py-3 rounded-full shadow-lg text-sm flex items-center gap-2" style="color: #136038;">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                Ver en Google Maps
              </span>
            </div>
          </a>
          <div class="text-white text-center py-3 flex items-center justify-center gap-2 font-body font-medium" style="background: #136038;">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
            Área Metropolitana del Valle de Aburrá — Haz clic para ver en Google Maps
          </div>
        </div>
      </div>
    </section>


    <!-- ═══════════════════════════════════════════════
         ARTÍCULOS
    ═══════════════════════════════════════════════ -->
    {latestPosts.length > 0 && (
      <section class="latest-articles py-20 relative overflow-hidden" style="background: linear-gradient(160deg, #5CE8C0 0%, #7FFFD4 40%, #B8F5C8 100%);">
        <!-- Wave superior -->
        <div class="absolute top-0 left-0 w-full overflow-hidden leading-none" style="transform: rotate(180deg);">
          <svg viewBox="0 0 1440 60" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="none" style="display:block; width:100%; height:60px;">
            <path d="M0,30 C360,0 1080,60 1440,30 L1440,60 L0,60 Z" fill="#ffffff"/>
          </svg>
        </div>

        <div class="container mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
          <div class="max-w-6xl mx-auto">
            <div class="text-center mb-14 animate-on-scroll">
              <p class="text-sm font-heading font-bold uppercase tracking-widest mb-3" style="color: #0d4a2a;">Blog</p>
              <h2 class="text-3xl lg:text-4xl font-heading font-extrabold mb-4" style="color: #0d4a2a;">Últimas Publicaciones</h2>
              <p class="text-lg font-body" style="color: #1a5c35;">Mantente informado con los artículos más recientes sobre gerontología y bienestar</p>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
              {latestPosts.map((post) => (
                <article class="article-card bg-white rounded-2xl shadow-lg overflow-hidden hover:shadow-2xl transition-all duration-300 hover:-translate-y-2 animate-on-scroll">
                  <div class="article-image aspect-video overflow-hidden bg-gray-100 flex items-center justify-center">
                    <img
                      src={post.data.featuredImage || '/images/blog/default-article.jpg'}
                      alt={post.data.title}
                      class="max-w-full max-h-full object-contain transition-transform duration-300 hover:scale-105"
                      loading="lazy"
                    />
                  </div>
                  <div class="p-6">
                    <div class="mb-3">
                      <span class={`inline-block px-3 py-1 text-xs font-semibold rounded-full ${
                        post.data.category === 'gerontologia' ? 'bg-primary/10 text-primary' :
                        post.data.category === 'familias-cuidadores' ? 'bg-green-100 text-green-800' :
                        post.data.category === 'demencias-alzheimer' ? 'bg-blue-100 text-blue-800' :
                        post.data.category === 'salud-bienestar' ? 'bg-purple-100 text-purple-800' :
                        post.data.category === 'envejecimiento-sociedad' ? 'bg-orange-100 text-orange-800' :
                        post.data.category === 'recursos-herramientas' ? 'bg-teal-100 text-teal-800' :
                        post.data.category === 'experiencias-reflexiones' ? 'bg-pink-100 text-pink-800' :
                        post.data.category === 'nutricion' ? 'bg-green-100 text-green-800' :
                        post.data.category === 'ejercicio' ? 'bg-blue-100 text-blue-800' :
                        post.data.category === 'salud-mental' ? 'bg-purple-100 text-purple-800' :
                        'bg-gray-100 text-gray-800'
                      }`}>
                        {categoryLabels[post.data.category] || post.data.category}
                      </span>
                    </div>
                    <h3 class="text-lg font-heading font-bold mb-2 line-clamp-2" style="color: #136038;">
